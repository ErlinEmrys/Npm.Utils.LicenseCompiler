{
	"name": "license-compiler",
	"type": "module",
	"version": "0.0.8",
	"description": "Utility for managing licenses",
	"author": "Erlin Emrys",
	"license": "MIT",
	"homepage": "https://github.com/ErlinEmrys/Npm.Utils.LicenseCompiler#README",
	"repository":
	{
		"type": "git",
		"url": "git+https://github.com/ErlinEmrys/Npm.Utils.LicenseCompiler.git"
	},
	"bugs":
	{
		"url": "https://github.com/ErlinEmrys/Npm.Utils.LicenseCompiler/issues"
	},
	"keywords":
	[
		"license",
		"licence",
		"third",
		"party",
		"generate",
		"file"
	],
	"exports": {
		".": {
			"types": "dist/Cli.d.ts",
			"import": "dist/Cli.js"
		}
	},
	"main": "dist/Cli.js",
	"types": "dist/Cli.d.ts",
	"bin":
	{
		"license-compiler": "./dist/Cli.js"
	},
	"files": [ "LICENSE_THIRD_PARTIES.md", "dist" ],
	"scripts":
	{
		"dev": "tsx src/Cli.ts -m LICENSE_THIRD_PARTIES.md",
		"build": "tsup",
		"lint": "eslint .",
		"format": "eslint . --fix",
		"pub": "pnpm lint && pnpm build && pnpm publish"
	},
	"publishConfig":
	{
		"access": "public"
	},
	"dependencies":
	{
		"@commander-js/extra-typings": "14.0.0",
		"@erlinemrys/lib.common": "0.0.14",
		"commander": "14.0.3"
	},
	"devDependencies":
	{
		"@erlinemrys/eslint-config": "0.0.9",
		"@types/node": "25.6.0",
		"eslint": "9.39.4",
		"tsup": "8.5.1",
		"tsx": "4.21.0",
		"typescript": "5.8.3"
	}
}
